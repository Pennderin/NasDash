{
  "name": "nasdash",
  "version": "1.0.0",
  "description": "Desktop widget for monitoring Unraid NAS - services, Plex streams, media pipeline, speed tests, and more",
  "main": "main.js",
  "author": "Pennderin",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.pennderin.nasdash",
    "productName": "NasDash",
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "NasDash.exe"
    },
    "files": [
      "main.js",
      "index.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "speedtest.exe",
        "to": "speedtest.exe"
      }
    ]
  },
  "devDependencies": {
    "electron": "^36.3.1",
    "electron-builder": "^25.1.8"
  }
}
